! Warp Router — FRR configuration
! Generated by 'warp apply'. Do not edit manually.

frr version 10
frr defaults traditional

hostname gw-dual
log syslog informational
service integrated-vtysh-config
!
!
! ECMP default routes (FRR merges equal-cost routes automatically)
ip route 0.0.0.0/0 10.0.0.1 eth0
ip route 0.0.0.0/0 203.0.113.1 eth1
!
!
! BFD peers for WAN health
bfd
 peer 10.0.0.1
  detect-multiplier 3
  receive-interval 300
  transmit-interval 300
 !
 peer 203.0.113.1
  detect-multiplier 3
  receive-interval 300
  transmit-interval 300
 !
!
line vty
!
